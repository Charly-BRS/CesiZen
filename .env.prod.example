# .env.prod.example
# Variables d'environnement pour la production CESIZen.
#
# ⚠️  Ce fichier est un MODÈLE — il ne contient pas de vraies valeurs.
#     Pour déployer :
#       1. Copier ce fichier : cp .env.prod.example .env.prod
#       2. Renseigner toutes les valeurs (ne jamais committer .env.prod)
#       3. Lancer : docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Base de données PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=cesizen_prod
POSTGRES_USER=cesizen_prod_user
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort_32_chars

# ── Application Symfony ───────────────────────────────────────────────────────
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_app_secret_32_chars_hex

# ── JWT Authentication (LexikJWT) ─────────────────────────────────────────────
# Générer les clés avec : php bin/console lexik:jwt:generate-keypair --env=prod
# Puis encoder en base64 inline : base64 -w0 config/jwt/private.pem
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_jwt_passphrase

# ── CORS (origines autorisées pour l'API) ─────────────────────────────────────
# Mettre l'URL de votre frontend en production
# Exemple : https://www.mondomaine.fr
CORS_ALLOW_ORIGIN=https://CHANGE_ME_votre_domaine.fr

# ── Frontend React (Vite) ─────────────────────────────────────────────────────
# URL de l'API Symfony accessible depuis le navigateur des utilisateurs
# Exemple : https://api.mondomaine.fr
VITE_API_URL=https://CHANGE_ME_api_domaine.fr/api
